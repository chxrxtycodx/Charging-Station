from flask import Flask, request
import paho.mqtt.client as mqtt

app = Flask(__name__)

BROKER = "test.mosquitto.org"
PORT = 1883

devices = {}

def mqtt_publish(device, level, event):
    client = mqtt.Client()
    client.connect(BROKER, PORT)
    client.publish(f"OSOROC/{device}/battery", str(level))
    client.publish(f"OSOROC/{device}/event", event)
    client.disconnect()

@app.route('/battery', methods=['POST'])
def battery():
    data = request.json
    device = data.get('device', 'unknown')
    level = data.get('level', -1)
    state = data.get('state', 'update')
    devices[device] = {"level": level, "state": state}
    print(f"{device}: {level}% — {state}")
    mqtt_publish(device, level, state)
    return {"status": "ok"}, 200

@app.route('/', methods=['GET'])
def dashboard():
    html = "<h1>ChargeSense</h1>"
    for device, info in devices.items():
        html += f"<p>{device}: {info['level']}% — {info['event']}</p>"
    return html

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000)
